# Database (required — use your REAL Neon connection string, not a placeholder).
# Get it from: https://console.neon.tech → your project → Connection string (pooled).
# Example (replace with your actual host, user, password, and DB name):
# DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-XXXXX-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# NextAuth (for admin login)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-secret-here

# Optional: Vercel Blob — project image uploads go to Blob instead of local disk (see IMAGE_STORAGE.md)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
